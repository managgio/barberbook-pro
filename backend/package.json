{
  "name": "leblond-backend",
  "version": "0.0.1",
  "description": "Backend NestJS + Prisma para la aplicación de reservas de Le Blond.",
  "license": "MIT",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "node scripts/start-dev.mjs",
    "start:prod": "node dist/main.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "arch:check": "node scripts/check-architecture-boundaries.mjs",
    "migration:inventory:appointments": "node scripts/migration/generate-appointments-inventory.mjs",
    "migration:inventory:context-module-bridges": "node scripts/migration/generate-context-module-bridges-inventory.mjs",
    "migration:inventory:context-module-bridges:check": "node scripts/migration/generate-context-module-bridges-inventory.mjs --check",
    "migration:inventory:context-module-bridges:enforce-zero": "node scripts/migration/generate-context-module-bridges-inventory.mjs --check --require-zero-present",
    "migration:inventory:transition-artifacts": "node scripts/migration/generate-transition-artifacts-checklist.mjs",
    "migration:inventory:transition-artifacts:check": "node scripts/migration/generate-transition-artifacts-checklist.mjs --check",
    "migration:inventory:transition-artifacts:enforce-zero": "node scripts/migration/generate-transition-artifacts-checklist.mjs --check --require-zero-present",
    "migration:inventory:residual-debt": "node scripts/migration/generate-residual-debt-prioritization.mjs",
    "migration:runtime:preflight": "node scripts/migration/runtime-preflight.mjs",
    "migration:smoke:runtime": "npm run build && npm run migration:runtime:preflight && node scripts/migration/runtime-capability-smoke.mjs",
    "migration:smoke:runtime:auth": "npm run build && npm run migration:runtime:preflight && node scripts/migration/runtime-authenticated-smoke.mjs",
    "migration:smoke:runtime:parity": "node scripts/migration/runtime-parity-smoke.mjs",
    "migration:gate:release": "node scripts/migration/release-gate.mjs",
    "migration:gate:release:enforce": "npm run build && npm run migration:runtime:preflight && MIGRATION_RELEASE_GATE_ENABLED=true node scripts/migration/release-gate.mjs",
    "migration:gate:release:staging": "npm run build && npm run migration:runtime:preflight && MIGRATION_RELEASE_GATE_PROFILE=staging node scripts/migration/release-gate.mjs",
    "migration:gate:release:staging:fast": "MIGRATION_RELEASE_GATE_INCLUDE_CI_GUARDS=false MIGRATION_RELEASE_GATE_PROFILE=staging node scripts/migration/release-gate.mjs",
    "migration:gate:release:canary": "npm run build && npm run migration:runtime:preflight && MIGRATION_RELEASE_GATE_PROFILE=canary node scripts/migration/release-gate.mjs",
    "migration:gate:release:canary:fast": "MIGRATION_RELEASE_GATE_INCLUDE_CI_GUARDS=false MIGRATION_RELEASE_GATE_PROFILE=canary node scripts/migration/release-gate.mjs",
    "migration:gate:release:prod": "npm run build && npm run migration:runtime:preflight && MIGRATION_RELEASE_GATE_PROFILE=prod node scripts/migration/release-gate.mjs",
    "migration:gate:release:prod:fast": "MIGRATION_RELEASE_GATE_INCLUDE_CI_GUARDS=false MIGRATION_RELEASE_GATE_PROFILE=prod node scripts/migration/release-gate.mjs",
    "migration:gate:release:canary-prod": "npm run build && npm run migration:runtime:preflight && npm run migration:gate:release:canary:fast && npm run migration:gate:release:prod:fast",
    "migration:gate:ci": "npm run arch:check && npm run migration:inventory:transition-artifacts:enforce-zero && npm run migration:inventory:context-module-bridges:enforce-zero",
    "migration:baseline:maintenance": "npm run migration:gate:ci && npm run build && npm run migration:runtime:preflight && npm run migration:gate:release:staging:fast",
    "test": "node --test -r ts-node/register -r tsconfig-paths/register \"test/**/*.test.ts\"",
    "test:unit": "node --test -r ts-node/register -r tsconfig-paths/register \"test/unit/**/*.test.ts\"",
    "test:contract": "node --test -r ts-node/register -r tsconfig-paths/register \"test/contract/**/*.test.ts\"",
    "test:parity": "node --test -r ts-node/register -r tsconfig-paths/register \"test/parity/**/*.test.ts\"",
    "test:coverage": "node --test --experimental-test-coverage -r ts-node/register -r tsconfig-paths/register \"test/**/*.test.ts\"",
    "test:typecheck": "tsc -p test/tsconfig.json --noEmit",
    "test:coverage:gate": "node scripts/tests/coverage-gate.mjs",
    "test:changed": "node scripts/tests/run-affected-tests.mjs",
    "test:changed:list": "node scripts/tests/run-affected-tests.mjs --list",
    "test:advisor": "node scripts/tests/manual-actions-advisor.mjs",
    "test:policy": "node scripts/tests/enforce-test-change-policy.mjs",
    "test:e2e:smoke": "node scripts/tests/run-optional-e2e-smoke.mjs",
    "test:ci": "npm run test:unit && npm run test:contract && npm run test:parity && npm run test:coverage:gate && npm run test:e2e:smoke",
    "tenant:scope:check": "node scripts/check-tenant-scope.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:backfill": "ts-node prisma/backfill.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^12.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "openai": "^4.67.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stripe": "^14.25.0",
    "twilio": "^5.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prisma": "^5.15.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
